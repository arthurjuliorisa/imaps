# Database
DATABASE_URL="postgresql://user:password@localhost:5432/imaps"

# NextAuth Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-strong-random-secret-minimum-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# Admin API Secret
# Generate with: openssl rand -base64 32
ADMIN_SECRET="replace-with-strong-random-secret-minimum-32-characters"
API_KEY_SECRET="replace-with-generated-api-key-for-client"

IP_WHITELIST=192.168.1.100,10.0.0.50
IP_WHITELIST_ENABLED=false

# Logging
LOG_LEVEL=info
NODE_ENV=development

# Environment Phase Configuration
# Controls cleanup API and other environment-specific features
# IMPORTANT: Used by detectEnvironmentPhase() in cleanup/route.ts
# - development: Full access to cleanup API for local testing
# - staging: Full access to cleanup API for staging/QA testing  
# - production: Cleanup API disabled (default fallback, safest option)
#
# Priority order in code:
#   1. NEXT_PUBLIC_ENVIRONMENT_PHASE (highest priority)
#   2. NODE_ENV (only 'development' is recognized)
#   3. DATABASE_PHASE (alternative flag)
#   4. Default to 'production' (safest fallback)
#
# Recommended setup:
#   - Local dev: NEXT_PUBLIC_ENVIRONMENT_PHASE=development
#   - Staging: NEXT_PUBLIC_ENVIRONMENT_PHASE=staging
#   - Production: Leave unset (will default to 'production')
NEXT_PUBLIC_ENVIRONMENT_PHASE=development

# Validation Configuration
# Set to 'true' to allow future dates in validation (useful for testing/staging)
# Default: false (enforce date validation in production)
ALLOW_FUTURE_DATES=false

# Timezone Configuration for Cron Service
# End-of-day snapshot calculation time: 00:05 in this timezone
# Supported: UTC, WIB (UTC+7), SGT (UTC+8), HKT (UTC+8), JST (UTC+9), EST (UTC-5), PST (UTC-8), IST (UTC+5:30), UTC±N
# Default: system timezone
APP_TIMEZONE=WIB

# Cron Schedule Configuration
# Format: standard cron expression (minute hour day month weekday)
# 
# CRON_RECALC_QUEUE_SCHEDULE: Process pending snapshot recalculation queue items
#   - Default (production): "*/15 * * * *" (every 15 minutes)
#   - Development: "*/1 * * * *" (every 1 minute) or "*/5 * * * *" (every 5 minutes)
#
# CRON_DAILY_SNAPSHOT_SCHEDULE: Calculate daily stock snapshots
#   - Default (production): "5 0 * * *" (00:05 UTC daily - end-of-day)
#   - Development: "*/5 * * * *" (every 5 minutes) for faster testing
#
# Uncomment and customize for your environment:
# CRON_RECALC_QUEUE_SCHEDULE="*/15 * * * *"
# CRON_DAILY_SNAPSHOT_SCHEDULE="5 0 * * *"

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=1200
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_BURST=200

# Optional Configuration
# API Base URL (defaults to '/api' if not set)
# NEXT_PUBLIC_API_BASE_URL="/api"

# Background Jobs (set to 'false' to disable auto-start in production)
# ENABLE_JOBS="true"
SKIP_SEEDERS=transaction

INSW_API_KEY=secret_api_key
INSW_UNIQUE_KEY_TEST=
INSW_UNIQUE_KEY_REAL=
INSW_USE_TEST_MODE=true/false
INSW_NPWP=080988899